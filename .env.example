# Phase toggle — set to "true" when e-commerce is ready
NEXT_PUBLIC_ECOMMERCE_ENABLED=false

# Site URL for SEO (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://noelagritv.com

# Auth.js (NextAuth v5)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated list of Google emails allowed to access /admin
ADMIN_EMAILS=

# Vercel Blob storage
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=

# ----------------------------------------------------------------------------
# COD checkout (Task 6 — submitOrder action)
# ----------------------------------------------------------------------------

# Google Sheets — orders write target (service-account auth)
# Provisioning steps:
#   1. Google Cloud Console → create project → enable Google Sheets API
#   2. Create a service account, download its JSON key
#   3. Create a Google Sheet, rename the first tab to "Orders" (exact, case-sensitive)
#   4. Share the Sheet with the service account email as Editor
#   5. Copy the long ID from the Sheet URL into GOOGLE_SHEET_ID below
#   6. From the JSON key file, copy `client_email` → GOOGLE_SERVICE_ACCOUNT_EMAIL
#   7. From the JSON key file, copy `private_key` → GOOGLE_PRIVATE_KEY
#      Replace every real newline in the key with literal "\n" and wrap in double quotes.
#      Example: GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Cloudflare Turnstile — anti-spam on /checkout (invisible widget)
# Provisioning: https://dash.cloudflare.com/?to=/:account/turnstile → Add Site → mode "Invisible"
#
# DEV / LOCAL TESTING — Cloudflare provides public test keys you can use without
# creating a site. Pasting these into .env.local lets you submit /checkout end-to-end
# while developing. NEVER ship these to production.
#   Always-passes site key:  1x00000000000000000000AA   secret: 1x0000000000000000000000000000000AA
#   Always-fails site key:   2x00000000000000000000AB   secret: 2x0000000000000000000000000000000AA
#   Forces interactive:      3x00000000000000000000FF   secret: 1x0000000000000000000000000000000AA
# Reference: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
